import streamlit as st
from moviepy.editor import ImageClip, concatenate_videoclips, AudioFileClip, vfx
from PIL import Image
import tempfile
import os

st.set_page_config(page_title="비요일 영상 제작소", page_icon="☔")
st.title("☔ 비요일(Biyoil) 숏폼 자동 제작기")
st.write("버전 2.0 - 이미지 리사이징 엔진 최적화 완료")

# 파일 업로드 섹션
st.subheader("1. 소스 업로드")
images = st.file_uploader("제품 사진들을 여러 장 선택하세요", accept_multiple_files=True, type=['jpg', 'jpeg', 'png'])
logo = st.file_uploader("브랜드 로고 이미지를 올려주세요", type=['jpg', 'jpeg', 'png'])
bgm = st.file_uploader("배경음악(MP3)을 올려주세요 (선택사항)", type=['mp3'])

def resize_image_pil(input_path, output_path, size=(1080, 1920)):
    """이미지를 9:16 비율로 강제로 맞춥니다."""
    with Image.open(input_path) as img:
        # 배경을 검정색으로 채우고 이미지를 가운데 맞춤
        img.thumbnail(size, Image.Resampling.LANCZOS)
        new_img = Image.new("RGB", size, (0, 0, 0))
        new_img.paste(img, ((size[0] - img.size[0]) // 2, (size[1] - img.size[1]) // 2))
        new_img.save(output_path, "PNG")

if st.button("✨ 영상 생성 시작"):
    if images and logo:
        with st.spinner('영상을 우아하게 제작 중입니다... (약 1~2분 소요)'):
            try:
                clips = []
                # 1. 사진 클립 생성
                for img_file in images:
                    with tempfile.NamedTemporaryFile(delete=False, suffix='.png') as tmp_in:
                        tmp_in.write(img_file.read())
                        tmp_out_path = tmp_in.name + "_resized.png"
                        # PIL로 미리 크기 조절 (에러 방지 핵심)
                        resize_image_pil(tmp_in.name, tmp_out_path)
                        
                        clip = ImageClip(tmp_out_path).set_duration(2.0)
                        clip = clip.set_fps(24).crossfadein(0.5)
                        clips.append(clip)
                
                # 2. 로고 엔딩
                with tempfile.NamedTemporaryFile(delete=False, suffix='.png') as l_in:
                    l_in.write(logo.read())
                    l_out_path = l_in.name + "_resized.png"
                    resize_image_pil(l_in.name, l_out_path)
                    
                    logo_clip = ImageClip(l_out_path).set_duration(4.0)
                    # 살짝 커지는 무빙 효과 추가
                    logo_clip = logo_clip.fx(vfx.resize, lambda t: 1 + 0.02 * t)
                    logo_clip = logo_clip.set_fps(24).crossfadein(1.0)
                    clips.append(logo_clip)
                
                # 3. 영상 합치기
                final_video = concatenate_videoclips(clips, method="compose")
                
                # 4. 음악 입히기
                if bgm:
                    with tempfile.NamedTemporaryFile(delete=False, suffix='.mp3') as mfile:
                        mfile.write(bgm.read())
                        audio = AudioFileClip(mfile.name).set_duration(final_video.duration)
                        final_video = final_video.set_audio(audio)
                
                output_filename = "biyoil_final.mp4"
                final_video.write_videofile(output_filename, fps=24, codec="libx264", audio_codec="aac")
                
                st.video(output_filename)
                st.success("🎉 완성되었습니다! 영상 위에서 '다른 이름으로 저장'하세요.")
                
            except Exception as e:
                st.error(f"오류가 발생했습니다: {e}")
    else:
        st.error("사진과 로고를 모두 등록해주세요.")
